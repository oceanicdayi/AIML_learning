# ============================================
# CWA AI Knowledge Hub — 環境變數範本
# 複製此檔為 .env 並填入實際值
# cp .env.example .env
# ============================================

# Google Drive —— gdown 需要 cookies 或 API key 才能存取受限資料夾
# 方法 A: 使用 Google API Key (建議)
GOOGLE_API_KEY=

# 方法 B: 使用 OAuth Client (rclone 使用)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Drive 來源資料夾 ID
GDRIVE_FOLDER_ID=1clBHKBIUBhP1jcvDN3tgtfQ7N0NuGuMb

# Hugging Face —— 部署至 HF Spaces 時使用
HF_TOKEN=
HF_SPACE_NAME=

# GitHub —— Pages 部署 (通常由 GitHub Actions 自動注入)
GITHUB_TOKEN=
GITHUB_REPOSITORY=
